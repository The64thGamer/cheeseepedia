                                        <li>Netgear Nighthawk RAX 43</li>
                                        <li>Netgear Nighthawk RAX 50</li>
                                        <li>TP Link Archer AX 50</li>
                                        <li>TP Link Archer AX 73</li>
                                    </ul>
